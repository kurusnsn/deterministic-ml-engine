# Supabase (required for auth features)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3100
NEXT_PUBLIC_GATEWAY_URL=/api/gateway
GATEWAY_INTERNAL_URL=http://localhost:8010
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Dev mock auth (optional)
NEXT_PUBLIC_MOCK_AUTH_ENABLED=false
NEXT_PUBLIC_MOCK_USER_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_MOCK_USER_EMAIL=mock@example.com
NEXT_PUBLIC_MOCK_USER_NAME=Mock User
NEXT_PUBLIC_MOCK_SESSION_ID=00000000-0000-0000-0000-000000000001
# Options: free | basic | plus
NEXT_PUBLIC_MOCK_SUBSCRIPTION_PLAN=free
