{
  "components": {
    "schemas": {
      "BookMove": {
        "properties": {
          "averageRating": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Averagerating"
          },
          "black": {
            "title": "Black",
            "type": "integer"
          },
          "draws": {
            "title": "Draws",
            "type": "integer"
          },
          "san": {
            "title": "San",
            "type": "string"
          },
          "white": {
            "title": "White",
            "type": "integer"
          }
        },
        "required": [
          "san",
          "white",
          "black",
          "draws"
        ],
        "title": "BookMove",
        "type": "object"
      },
      "BookResponse": {
        "properties": {
          "fen": {
            "title": "Fen",
            "type": "string"
          },
          "fetch": {
            "default": "success",
            "title": "Fetch",
            "type": "string"
          },
          "moves": {
            "items": {
              "$ref": "#/components/schemas/BookMove"
            },
            "title": "Moves",
            "type": "array"
          },
          "ratings": {
            "items": {
              "type": "string"
            },
            "title": "Ratings",
            "type": "array"
          },
          "speeds": {
            "items": {
              "type": "string"
            },
            "title": "Speeds",
            "type": "array"
          },
          "type": {
            "title": "Type",
            "type": "string"
          },
          "variant": {
            "title": "Variant",
            "type": "string"
          }
        },
        "required": [
          "fen",
          "variant",
          "type",
          "ratings",
          "speeds"
        ],
        "title": "BookResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "OpeningRequest": {
        "properties": {
          "moves": {
            "items": {
              "type": "string"
            },
            "title": "Moves",
            "type": "array"
          }
        },
        "required": [
          "moves"
        ],
        "title": "OpeningRequest",
        "type": "object"
      },
      "OpeningResponse": {
        "properties": {
          "cached": {
            "default": false,
            "title": "Cached",
            "type": "boolean"
          },
          "content": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Content"
          },
          "title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Title"
          }
        },
        "required": [
          "content",
          "title"
        ],
        "title": "OpeningResponse",
        "type": "object"
      },
      "PopularityItem": {
        "properties": {
          "fen": {
            "title": "Fen",
            "type": "string"
          },
          "games": {
            "title": "Games",
            "type": "integer"
          }
        },
        "required": [
          "fen",
          "games"
        ],
        "title": "PopularityItem",
        "type": "object"
      },
      "PopularityRequest": {
        "properties": {
          "fens": {
            "description": "List of FEN positions to get popularity for",
            "items": {
              "type": "string"
            },
            "title": "Fens",
            "type": "array"
          }
        },
        "required": [
          "fens"
        ],
        "title": "PopularityRequest",
        "type": "object"
      },
      "PopularityResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/PopularityItem"
            },
            "title": "Items",
            "type": "array"
          }
        },
        "required": [
          "items"
        ],
        "title": "PopularityResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Opening Book Service",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    },
    "/opening/book": {
      "get": {
        "operationId": "get_opening_book_opening_book_get",
        "parameters": [
          {
            "description": "Full FEN string",
            "in": "query",
            "name": "fen",
            "required": true,
            "schema": {
              "description": "Full FEN string",
              "title": "Fen",
              "type": "string"
            }
          },
          {
            "description": "Variant name",
            "in": "query",
            "name": "variant",
            "required": false,
            "schema": {
              "default": "standard",
              "description": "Variant name",
              "title": "Variant",
              "type": "string"
            }
          },
          {
            "description": "Explorer source: lichess|master",
            "in": "query",
            "name": "type",
            "required": false,
            "schema": {
              "default": "lichess",
              "description": "Explorer source: lichess|master",
              "title": "Type",
              "type": "string"
            }
          },
          {
            "description": "Allowed rating buckets",
            "in": "query",
            "name": "ratings",
            "required": false,
            "schema": {
              "default": [
                "1600",
                "1800",
                "2000",
                "2200",
                "2500"
              ],
              "description": "Allowed rating buckets",
              "items": {
                "type": "string"
              },
              "title": "Ratings",
              "type": "array"
            }
          },
          {
            "description": "Time controls",
            "in": "query",
            "name": "speeds",
            "required": false,
            "schema": {
              "default": [
                "bullet",
                "blitz",
                "rapid",
                "classical"
              ],
              "description": "Time controls",
              "items": {
                "type": "string"
              },
              "title": "Speeds",
              "type": "array"
            }
          },
          {
            "description": "Cache TTL seconds",
            "in": "query",
            "name": "ttl",
            "required": false,
            "schema": {
              "default": 300.0,
              "description": "Cache TTL seconds",
              "maximum": 3600,
              "minimum": 0,
              "title": "Ttl",
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Opening Book"
      }
    },
    "/opening/health": {
      "get": {
        "operationId": "health_opening_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    },
    "/opening/popularity/by-fens": {
      "post": {
        "description": "Get total game counts for a list of FEN positions.\nUsed to calculate popularity for opening cards.\n\nSums games across all speeds and rating buckets for each FEN.",
        "operationId": "get_popularity_by_fens_opening_popularity_by_fens_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PopularityRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PopularityResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Popularity By Fens"
      }
    },
    "/opening/theory": {
      "post": {
        "description": "WikiBooks opening theory lookup",
        "operationId": "get_opening_theory_opening_theory_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OpeningRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpeningResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Opening Theory"
      }
    }
  }
}
