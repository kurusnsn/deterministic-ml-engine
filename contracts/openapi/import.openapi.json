              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Fetch Game By Url",
        "tags": [
          "games"
        ]
      }
    },
    "/games/fetch/stream": {
      "post": {
        "description": "Stream games as NDJSON for dynamic UI updates.\nEnforces standard-only (variants excluded) and honors filters.",
