    },
    "/games/fetch-by-url": {
      "post": {
        "description": "Fetch a single game by URL from Lichess or Chess.com.\nExpected payload: {\"url\": \"...\", \"source\": \"lichess.org\"|\"chess.com\"}\n\nSECURITY INPUT-4: URL validated against SSRF allowlist.",
        "operationId": "fetch_game_by_url_games_fetch_by_url_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": true,
